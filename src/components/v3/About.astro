---
import { business } from '../../data/business.js';
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,300;1,9..144,500&family=Karla:wght@400;500;700&display=swap" rel="stylesheet" />

<section class="about" id="about">
  <div class="container">
    <div class="section-header reveal">
      <span class="label-tag">Chi Sono</span>
      <h2 class="section-title">Formazione</h2>
      <p class="section-subtitle">Il percorso che mi ha portata fin qui.</p>
    </div>

    <div class="timeline reveal" data-stagger>
      {business.formazione.map(f => (
        <div class="timeline-item">
          <span class="timeline-anno">{f.anno}</span>
          <div class="timeline-body">
            <strong>{f.titolo}</strong>
            <span>{f.desc}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about {
    --surface: #FDFCFE;
    --surface-alt: #F6F2FA;
    --primary-500: #6D3B7E;
    --primary-900: #2A1538;
    --neutral-600: #7A6B85;
    --font-display: 'Fraunces', Georgia, serif;
    --font-body: 'Karla', system-ui, sans-serif;

    background: var(--surface);
    padding: 7rem 2.5rem;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .label-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--primary-500);
    background: rgba(109, 59, 126, 0.08);
    padding: 0.35rem 1rem;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--primary-500);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--neutral-600);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .timeline-item {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 1.2rem 1.5rem;
    background: var(--surface-alt);
    border-radius: 8px;
    border-left: 3px solid var(--primary-500);
  }

  .timeline-anno {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--primary-500);
    white-space: nowrap;
    min-width: 100px;
  }

  .timeline-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--primary-900);
  }

  .timeline-body span {
    color: var(--neutral-600);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .about {
      padding: 5rem 1.25rem;
    }

    .timeline-item {
      flex-direction: column;
      gap: 0.3rem;
    }

    .timeline-anno {
      min-width: auto;
    }
  }
</style>
