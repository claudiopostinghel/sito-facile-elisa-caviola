---
import { business } from '../../data/business.js';
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,300;1,9..144,500&family=Karla:wght@400;500;700&display=swap" rel="stylesheet" />

<nav class="navbar" id="navbar">
  <div class="navbar-inner">
    <a href="#" class="logo">{business.nome}</a>

    <button class="menu-toggle" aria-label="Apri menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <div class="nav-links">
      {business.nav.filter(n => ['Lavori', 'Processo', 'Chi Sono', 'Contatti'].includes(n.label)).map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
      <a href="#contatto" class="cta-link">Scrivimi</a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = navbar?.querySelector('.menu-toggle');
  const links = navbar?.querySelector('.nav-links');

  let scrolled = false;
  const onScroll = () => {
    const now = window.scrollY > 60;
    if (now !== scrolled) {
      scrolled = now;
      navbar?.classList.toggle('scrolled', now);
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    links?.classList.toggle('open', !open);
  });

  links?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      links?.classList.remove('open');
    });
  });
</script>

<style>
  .navbar {
    --surface: #FDFCFE;
    --primary-500: #6D3B7E;
    --accent: #9B6BB5;
    --text: #2A1538;
    --font-display: 'Fraunces', Georgia, serif;
    --font-body: 'Karla', system-ui, sans-serif;

    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(253, 252, 254, 0.95);
    backdrop-filter: blur(12px);
    transition: box-shadow 0.4s ease;
  }

  .navbar.scrolled {
    box-shadow: 0 2px 20px rgba(42, 21, 56, 0.08);
  }

  .navbar-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 1.1rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.35rem;
    color: var(--primary-500);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.2rem;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text);
    position: relative;
    transition: color 0.3s ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-500);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .cta-link {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 700;
    color: white;
    background: var(--primary-500);
    padding: 0.55rem 1.5rem;
    border-radius: 40px;
    transition: background-color 0.3s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    letter-spacing: 0.02em;
  }

  .cta-link:hover {
    background: #7D519A;
    transform: translateY(-2px);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }

  .bar {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .menu-toggle[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-toggle[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: flex;
    }

    .navbar-inner {
      padding: 1rem 1.25rem;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      flex-direction: column;
      background: var(--surface);
      padding: 1.5rem;
      gap: 1.2rem;
      box-shadow: 0 12px 32px rgba(42, 21, 56, 0.1);
      opacity: 0;
      transform: translateY(-10px);
      pointer-events: none;
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .nav-links.open {
      opacity: 1;
      transform: translateY(0);
      pointer-events: all;
    }
  }
</style>
