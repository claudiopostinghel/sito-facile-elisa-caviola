---
import { Image } from 'astro:assets';
import { business } from '../../data/business.js';
import monogrammiImg from '../../assets/images/monogrammi-overview.jpeg';
import africanImg from '../../assets/images/african-spirit-mockup-02.jpeg';
import teatroImg from '../../assets/images/teatro-poster-01.jpeg';
import zeitgeistImg from '../../assets/images/zeitgeist-03.jpeg';

const servicePairs = [
  { servizio: business.servizi[0], image: teatroImg, alt: 'Teatro Sociale — Brand Identity' },
  { servizio: business.servizi[1], image: africanImg, alt: 'African Spirit — Packaging Design' },
  { servizio: business.servizi[2], image: zeitgeistImg, alt: 'Zeitgeist — Fotografia Creativa' },
];
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,300;1,9..144,500&family=Karla:wght@400;500;700&display=swap" rel="stylesheet" />

<section class="servizi" id="servizi">
  <div class="container">
    <div class="section-header reveal">
      <span class="label-tag">Servizi</span>
      <h2 class="section-title">Cosa posso fare per te</h2>
    </div>

    <div class="services-grid" data-stagger>
      {servicePairs.map(({ servizio, image, alt }, i) => (
        <article class={`service-card ${i === 1 ? 'service-card--offset' : ''} reveal`}>
          <div class="service-image">
            <Image src={image} alt={alt} width={440} quality={80} />
          </div>
          <div class="service-content">
            <h3 class="service-name">{servizio.titolo}</h3>
            <p class="service-desc">{servizio.desc}</p>
            <a href="#contatto" class="service-link">
              Parliamone
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .servizi {
    --surface: #FDFCFE;
    --surface-alt: #F6F2FA;
    --primary-500: #6D3B7E;
    --primary-600: #5A2E68;
    --primary-900: #2A1538;
    --accent: #9B6BB5;
    --neutral-600: #7A6B85;
    --font-display: 'Fraunces', Georgia, serif;
    --font-body: 'Karla', system-ui, sans-serif;
    --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);

    background: var(--surface-alt);
    padding: 7rem 2.5rem;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .label-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--primary-500);
    background: rgba(109, 59, 126, 0.08);
    padding: 0.35rem 1rem;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--primary-500);
    letter-spacing: -0.02em;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .service-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(42, 21, 56, 0.06);
    transition: transform 0.5s var(--ease-bounce), box-shadow 0.4s ease;
  }

  .service-card--offset {
    transform: translateY(2rem);
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(42, 21, 56, 0.12);
  }

  .service-card--offset:hover {
    transform: translateY(calc(2rem - 6px));
  }

  .service-image {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .service-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s ease;
  }

  .service-card:hover .service-image :global(img) {
    transform: scale(1.05);
  }

  .service-content {
    padding: 1.8rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .service-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--primary-500);
    letter-spacing: -0.01em;
  }

  .service-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--neutral-600);
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--accent);
    margin-top: 0.5rem;
    transition: gap 0.3s var(--ease-bounce);
  }

  .service-link:hover {
    gap: 0.8rem;
  }

  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin: 0 auto;
    }

    .service-card--offset {
      transform: none;
    }

    .service-card--offset:hover {
      transform: translateY(-6px);
    }

    .servizi {
      padding: 5rem 1.25rem;
    }
  }
</style>
